{
  "name": "better-vapi-cli",
  "version": "0.2.0",
  "description": "Command-line interface for Vapi voice AI — for humans and AI agents. Installs the `bvapi` binary.",
  "type": "module",
  "bin": {
    "bvapi": "dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EvoTechMike/Better-Vapi-CLI.git"
  },
  "bugs": {
    "url": "https://github.com/EvoTechMike/Better-Vapi-CLI/issues"
  },
  "homepage": "https://github.com/EvoTechMike/Better-Vapi-CLI#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "vapi",
    "voice-ai",
    "cli",
    "claude",
    "claude-code",
    "skill",
    "agent"
  ],
  "license": "MIT"
}
